<Window x:Class="MasterMetrology.Utils.ConfirmStateChangesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16" MinHeight="120">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Message}"
                   TextWrapping="Wrap"
                   Width="360"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="80" Margin="0,0,8,0" IsDefault="True" Content="{Binding TxtApply}"
                    Click="Save_Click"/>
            <Button Width="80" Margin="0,0,8,0" IsCancel="True" Content="{Binding TxtDiscard}"
                    Click="Discard_Click"/>
			<Button Width="80" IsCancel="True" Content="{Binding TxtCancel}"
				    Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>