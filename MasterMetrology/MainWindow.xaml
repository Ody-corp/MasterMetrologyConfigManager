<Window x:Class="MasterMetrology.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MasterMetrology"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <DockPanel>
            <Menu DockPanel.Dock="Top">
                <MenuItem Header="File" >
                    <MenuItem Header="Import"/>
                    <MenuItem Header="Save"/>
                    <MenuItem Header="Save as"/>
                    <MenuItem Header="Exit" Click="ExitSoftware"/>
                </MenuItem>
                <MenuItem Header="Edit">
                    
                </MenuItem>
                <MenuItem Header="View">
                    <MenuItem Header="_Center" Click="ResetView_Click"/>
                    <MenuItem Header="Zoom">
                        <MenuItem Header="40%"/>
                        <MenuItem Header="60%"/>
                        <MenuItem Header="80%"/>
                        <MenuItem Header="100%"/>
                        <MenuItem Header="120%"/>
                        <MenuItem Header="150%"/>
                        <MenuItem Header="200%"/>
                        <MenuItem Header="250%"/>
                        <MenuItem Header="300%"/>
                    </MenuItem>
                </MenuItem>
            </Menu>
            <Grid>
                <Border x:Name="DiagramBorder" BorderBrush="Black" BorderThickness="1" ClipToBounds="True" Height="350" Width="400" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Grid>
                        <!-- bottom layer (background) of canvas view with grid -->
                        <Canvas x:Name="GridCanvas" Width="50000" Height="50000">
                            <Canvas.Background>
                                <DrawingBrush TileMode="Tile" Viewport="0,0,50,50" ViewportUnits="Absolute">
                                    <DrawingBrush.Drawing>
                                        <!-- white background -->
                                        <GeometryDrawing Brush="White">
                                            <!-- grid -->
                                            <GeometryDrawing.Pen>
                                                <Pen Brush="LightGray" Thickness="0.5"/>
                                            </GeometryDrawing.Pen>
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup>
                                                    <LineGeometry StartPoint="0,0" EndPoint="50,0"/>
                                                    <LineGeometry StartPoint="0,0" EndPoint="0,50"/>
                                                </GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Canvas.Background>
                            <!-- allows canvas to move and transport -->
                                <Canvas.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform x:Name="PanTransform" X="0" Y="0"/>
                                </TransformGroup>
                            </Canvas.RenderTransform>
                        </Canvas>

                        <!-- top layer: objects -->
                        <Canvas x:Name="DiagramCanvas" Width="50000" Height="50000" Background="Transparent">
                            <!-- transform and zoom locked with bottom layer -->
                                <Canvas.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="{Binding ElementName=ZoomTransform, Path=ScaleX}"
                                                    ScaleY="{Binding ElementName=ZoomTransform, Path=ScaleY}"/>
                                    <TranslateTransform X="{Binding ElementName=PanTransform, Path=X}"
                                                        Y="{Binding ElementName=PanTransform, Path=Y}"/>
                                </TransformGroup>
                            </Canvas.RenderTransform>

                            <!-- object for testing -->
                            <Grid Width="120" Height="60" Canvas.Left="25000" Canvas.Top="25000">
                                <Rectangle Fill="LightBlue" Stroke="Black" StrokeThickness="2"/>
                                <TextBlock Text="Tabuľka 1"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold"/>
                            </Grid>
                        </Canvas>
                    </Grid>
                </Border>
            </Grid>
            <Button Content="Button" Width="50" Height="20" Click="OnClickSpawnObject"/>
        </DockPanel>
    </Grid>
</Window>