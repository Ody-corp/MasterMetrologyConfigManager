<Window x:Class="MasterMetrology.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MasterMetrology"
        mc:Ignorable="d"
        Title="MainWindow" Height="1080" Width="1920" WindowState="Maximized">
    <Window.Resources>
        <Style TargetType="{x:Type ComboBoxItem}"
           BasedOn="{StaticResource {x:Type ComboBoxItem}}">
            <Setter Property="HorizontalContentAlignment"
                Value="{Binding Path=PlacementTarget.HorizontalContentAlignment,
                                RelativeSource={RelativeSource AncestorType={x:Type Popup}}}"/>
            <Setter Property="VerticalContentAlignment"
                Value="{Binding Path=PlacementTarget.VerticalContentAlignment,
                                RelativeSource={RelativeSource AncestorType={x:Type Popup}}}"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
    </Window.Resources>

    <Grid>
        <DockPanel>
            <Menu DockPanel.Dock="Top">
                <MenuItem Header="File" >
                    <MenuItem Header="Import" Command="{Binding ImportFileCommand}"/>
                    <MenuItem Header="Show States Debug" Click="ShowDebug_Click"/>
                    <MenuItem Header="Test" Click="Test_Test"/>
                    <Separator/>
                    <MenuItem Header="Save" Command="{Binding SaveCommand}"/>
                    <MenuItem Header="Save as" Command="{Binding SaveAsCommand}"/>
                    <Separator/>
                    <MenuItem Header="Exit" Command="{Binding ExitAppCommand}"/>
                </MenuItem>
                <MenuItem Header="Edit">
                    <MenuItem Header="New state">
                        <MenuItem Header="To root" Command="{Binding AddStateToRootCommand}"/>
                        <MenuItem Header="As SubState" Command="{Binding AddStateAsSubStateCommand}"/>
                    </MenuItem>
                    <MenuItem Header="Delete" >
                        <MenuItem Header="State" Command="{Binding DeleteSingleSelectedStateCommand}"/>
                        <MenuItem Header="Whole section" Command="{Binding DeleteWholeSelectedStateCommand}"/>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="View">
                    <MenuItem Header="_Center" Command="{Binding CenterViewCommand}"/>
                    <MenuItem Header="Zoom">
                        <MenuItem Header="40%"/>
                        <MenuItem Header="60%"/>
                        <MenuItem Header="80%"/>
                        <MenuItem Header="100%"/>
                        <MenuItem Header="120%"/>
                        <MenuItem Header="150%"/>
                        <MenuItem Header="200%"/>
                        <MenuItem Header="250%"/>
                        <MenuItem Header="300%"/>
                    </MenuItem>
                </MenuItem>
            </Menu>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                
                <Grid Height="auto" Grid.Column="0" x:Name="ViewPort" IsHitTestVisible="True">
                    <Border x:Name="DiagramBorder" BorderBrush="Black" BorderThickness="1" ClipToBounds="True" Height="auto" Width="auto" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <Grid>
                            <!-- bottom layer (background) of canvas view with grid -->
                            <Canvas x:Name="GridCanvas" Width="50000" Height="50000" 
                                    >
                                <Canvas.Background>
                                    <DrawingBrush TileMode="Tile" Viewport="0,0,50,50" ViewportUnits="Absolute">
                                        <DrawingBrush.Drawing>
                                            <!-- white background -->
                                            <GeometryDrawing Brush="White">
                                                <!-- grid -->
                                                <GeometryDrawing.Pen>
                                                    <Pen Brush="LightGray" Thickness="0.5"/>
                                                </GeometryDrawing.Pen>
                                                <GeometryDrawing.Geometry>
                                                    <GeometryGroup>
                                                        <LineGeometry StartPoint="0,0" EndPoint="50,0"/>
                                                        <LineGeometry StartPoint="0,0" EndPoint="0,50"/>
                                                    </GeometryGroup>
                                                </GeometryDrawing.Geometry>
                                            </GeometryDrawing>
                                        </DrawingBrush.Drawing>
                                    </DrawingBrush>
                                </Canvas.Background>
                                <!-- allows canvas to move and transport -->
                                <Canvas.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1"/>
                                        <TranslateTransform x:Name="PanTransform" X="0" Y="0"/>
                                    </TransformGroup>
                                </Canvas.RenderTransform>
                            </Canvas>

                            <!-- top layer: objects -->
                            <Canvas x:Name="DiagramCanvas" Width="50000" Height="50000" Background="Transparent" ContextMenu="{StaticResource rightClickContextMenu}" PreviewMouseRightButtonDown="DiagramCanvas_PreviewMouseRightButtonDown">
                                <Canvas x:Name="GraphLayer" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent"/>
                                <!-- PreviewMouseLeftButtonDown=GraphLayer_PreviewMouseLeftButtonDown -->

                                <!-- transform and zoom locked with bottom layer -->
                                <Canvas.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="{Binding ElementName=ZoomTransform, Path=ScaleX}"
                                        ScaleY="{Binding ElementName=ZoomTransform, Path=ScaleY}"/>
                                        <TranslateTransform X="{Binding ElementName=PanTransform, Path=X}"
                                            Y="{Binding ElementName=PanTransform, Path=Y}"/>
                                    </TransformGroup>
                                </Canvas.RenderTransform>
                            </Canvas>
                        </Grid>
                    </Border>
                </Grid>
                <Grid Height="auto" Grid.Column="1" MinWidth="300">
                    <TabControl Margin="12">
                        <TabItem Header="States">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <!-- labels -->
                                    <ColumnDefinition Width="*"/>
                                    <!-- inputs -->
                                </Grid.ColumnDefinitions>
                                <GroupBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Header="Data" Margin="0,8,0,0">
                                    <Grid Margin="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <!-- Name -->
                                            <RowDefinition Height="Auto"/>
                                            <!-- ID -->
                                            <RowDefinition Height="Auto"/>
                                            <!-- Full Index -->
                                            <RowDefinition Height="Auto"/>
                                            <!-- Output -->
                                            <RowDefinition Height="Auto"/>
                                            <!-- Parent -->
                                            <RowDefinition Height="Auto"/>
                                            <!-- Children label -->
                                            <RowDefinition Height="*"/>
                                            <!-- Children list -->
                                            <RowDefinition Height="Auto"/>
                                            <!-- children add/remove -->
                                            <RowDefinition Height="Auto"/>
                                            <!-- Apply -->
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Label Grid.Row="0" Grid.Column="0" Content="Name"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Margin="2.5"
                        Text="{Binding DraftName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                        <Label Grid.Row="1" Grid.Column="0" Content="ID"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Margin="2.5"
                        Text="{Binding DraftIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                        <Label Grid.Row="2" Grid.Column="0" Content="Full Index"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Margin="2.5" IsReadOnly="True" Background="LightGray"
                        Text="{Binding SelectedState.FullIndex}"/>

                                        <Label Grid.Row="3" Grid.Column="0" Content="Output"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" Margin="2.5"
                    Text="{Binding DraftOutput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                        <!-- PARENT: combobox instead of simple textbox -->
                                        <Label Grid.Row="4" Grid.Column="0" Content="Parent"/>
                                        <ComboBox Grid.Row="4" Grid.Column="1" Margin="2.5"
                      ItemsSource="{Binding ParentCandidates}"
                      SelectedItem="{Binding DraftParent, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock>
                            <Run Text="{Binding FullIndex}"/>
                            <Run Text=" - "/>
                            <Run Text="{Binding Name}"/>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <!-- Children area: list + add/remove -->
                                        <Label Grid.Row="5" Grid.Column="0" Content="Children" VerticalAlignment="Top"/>

                                        <ListBox Grid.Row="5" Grid.Column="1" Height="150"
                     x:Name="LstChildren"
                     Margin="2.5"
                     SelectionMode="Single"
                     ItemsSource="{Binding DraftChildren}"
                     SelectedItem="{Binding SelectedChild, Mode=TwoWay}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="Black"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding isDraftAdded}" Value="True">
                                                                        <Setter Property="Foreground" Value="Green"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                <Run Text="{Binding FullIndex}"/>
                                <Run Text=" - "/>
                                <Run Text="{Binding Name}"/>
                                <InlineUIContainer>
                                    <TextBlock Text="(added)"
                                               Margin="6,0,0,0"
                                               Foreground="Green"
                                               Visibility="{Binding IsDraftAdded, Converter={StaticResource BoolToVis}}"/>
                                </InlineUIContainer>        
                        </TextBlock>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <ComboBox Grid.Row="6" Grid.Column="1" x:Name="CmbChild" Width="Auto" Margin="2,0,2,0"
                          ItemsSource="{Binding ChildCandidates}"
                          SelectedItem="{Binding ChildToAdd, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="Black"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDraftRemoved}" Value="True">
                                                                        <Setter Property="Foreground" Value="Red"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                <Run Text="{Binding FullIndex}"/>
                                <Run Text=" - "/>
                                <Run Text="{Binding Name}"/>
                                <InlineUIContainer>
                                    <TextBlock Text="(removed)"
                                               Margin="6,0,0,0"
                                               Foreground="Red"
                                               Visibility="{Binding IsDraftRemoved, Converter={StaticResource BoolToVis}}"/>
                                </InlineUIContainer>
                        </TextBlock>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>



                                        <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal" Margin="2.5,6,2.5,0">
                                            <Button Content="Add child" Width="80"
                        Command="{Binding AddChildCommand}"/>
                                            <Button Content="Remove selected" Width="100" Margin="8,0,0,0"
                        Command="{Binding RemoveChildCommand}"/>
                                        </StackPanel>
                                        <Button Grid.Row="8" Grid.Column="1"
                    Content="Apply"
                    Width="100"
                    Margin="0,10,2.5,2.5"
                    HorizontalAlignment="Right"
                    Command="{Binding ApplyCommand}"/>

                                    </Grid>
                                </GroupBox>

                                <!-- Transitions area -->
                                <GroupBox Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Header="Transitions" Margin="0,8,0,0">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="25,4,0,8">
                                            <Label>Input</Label>
                                            <TextBox MinWidth="40" MaxWidth="50" Margin="0,3,8,3" Text="{Binding NewTransitionInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                            <Label>Target</Label>
                                            <ComboBox x:Name="CmbTransitionTarget" MinWidth="300" Margin="0,3,8,3"
                          ItemsSource="{Binding FlatStates}"
                          SelectedItem="{Binding SelectedTransitionTarget, Mode=TwoWay}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock>
                                <Run Text="{Binding FullIndex}"/>
                                <Run Text=" - "/>
                                <Run Text="{Binding Name}"/>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>


                                        </StackPanel>
                                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="25,4,0,8">
                                            <Button Content="Add" Width="50" Margin="0,3,8,3" 
                        Command="{Binding AddTransitionCommand}"/>
                                            <Button Content="Remove selected" Margin="0,3,0,3" Width="120"
                        Command="{Binding RemoveTransitionCommand}"/>
                                        </StackPanel>
                                        <ListBox ItemsSource="{Binding TransitionsView}"
                     SelectedItem="{Binding SelectedTransition, Mode=TwoWay}"
                     DisplayMemberPath="DisplayText" Margin="20,10,20,10"/>
                                    </DockPanel>
                                </GroupBox>
                            </Grid>
                        </TabItem>
                        <TabItem Header="Input Definitions">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- header row -->
                                <Grid Grid.Row="0" Margin="6,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions> 

                                   
                                        <TextBlock Grid.Column="0" Text="ID" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="Name" FontWeight="SemiBold"/>
                                        <Button Grid.Column="2" Content="Add new" Width="60" Margin="0,0,8,0" HorizontalAlignment="Right"
                                            Command="{Binding AddInputCommand}"/>

                                        <Button Grid.Column="3" Content="Remove selected" Width="120" Margin="0,0,4,0" HorizontalAlignment="Right"
                                            Command="{Binding RemoveInputCommand}"/>
                                    
                                </Grid>

                                <!-- list -->
                                <ListBox Grid.Row="1" SelectedItem="{Binding SelectedInput, Mode=TwoWay}" ItemsSource="{Binding InputsDef}" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- editable ID -->
                                                <TextBox Grid.Column="0"
                                                         x:Name="ID"
                                                     Margin="0,0,6,0"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     HorizontalAlignment="Stretch"
                                                     Text="{Binding ID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Focusable="False"
                                                     IsReadOnly="True"
                                                     local:InlineEditBehavior.Enable="True"/>

                                                <!-- editable Name (toto sa roztiahne na full) -->
                                                <TextBox Grid.Column="1"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     HorizontalAlignment="Stretch"
                                                     Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Focusable="False"
                                                     IsReadOnly="True"
                                                     local:InlineEditBehavior.Enable="True"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </TabItem>
                        <TabItem Header="Output Definitions">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- header -->
                                <Grid Grid.Row="0" Margin="6,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="ID" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="Name" FontWeight="SemiBold"/>
                                    <Button Grid.Column="2" Content="Add new" Width="60" Margin="0,0,8,0"
                                            Command="{Binding AddOutputCommand}"/>
                                    <Button Grid.Column="3" Content="Remove selected" Width="120"
                                            Command="{Binding RemoveOutputCommand}"/>
                                </Grid>

                                <!-- list -->
                                <ListBox Grid.Row="1"
                 ItemsSource="{Binding OutputsDef}"
                 SelectedItem="{Binding SelectedOutput, Mode=TwoWay}"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <!-- klik na riadok vyberie item -->
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="2"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border Background="{TemplateBinding Background}">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter Property="Background" Value="#22007ACC"/>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#11007ACC"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>

                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,5,0,5">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBox x:Name="ID"
                                     Grid.Column="0"
                                     Margin="0,0,8,0"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     IsReadOnly="True"
                                     local:InlineEditBehavior.Enable="True"
                                     Text="{Binding ID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                                    <TextBox x:Name="Name"
                                     Grid.Column="1"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     IsReadOnly="True"
                                     local:InlineEditBehavior.Enable="True"
                                     Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>

                                                <!-- bottom: bool flags (wrap) -->
                                                <WrapPanel Grid.Row="1" Margin="0,4,0,0">
                                                    <CheckBox Content="Definition"
                                      Margin="0,0,12,0"
                                      IsChecked="{Binding UpdateDefinition, Mode=TwoWay}"/>
                                                    <CheckBox Content="Parameters"
                                      Margin="0,0,12,0"
                                      IsChecked="{Binding UpdateParameters, Mode=TwoWay}"/>
                                                    <CheckBox Content="Calibration"
                                      Margin="0,0,12,0"
                                      IsChecked="{Binding UpdateCalibration, Mode=TwoWay}"/>
                                                    <CheckBox Content="Measured"
                                      Margin="0,0,12,0"
                                      IsChecked="{Binding UpdateMeasuredData, Mode=TwoWay}"/>
                                                    <CheckBox Content="Processed"
                                      Margin="0,0,12,0"
                                      IsChecked="{Binding UpdateProcessedData, Mode=TwoWay}"/>
                                                </WrapPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- buttons -->
                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                    
                                </StackPanel>
                            </Grid>
                        </TabItem>

                    </TabControl>
                    
                </Grid>
            </Grid>
        </DockPanel>
    </Grid>
</Window>