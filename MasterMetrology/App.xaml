<Application x:Class="MasterMetrology.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ContextMenu x:Key="rightClickContextMenu" x:Name="contextMenu" x:Shared="False">
            <MenuItem Header="New state">
                <MenuItem Header="To root" Command="{Binding AddStateToRootAtPointCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=Tag}"/>
                <MenuItem Header="As SubState" Command="{Binding AddStateAsSubStateCMCommand}" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
            </MenuItem>
            <MenuItem Header="Delete">
                <MenuItem Header="State" Command="{Binding DeleteSingleStateCommand}" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                <MenuItem Header="Whole section" Command="{Binding DeleteWholeStateCommand}" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
            </MenuItem>
            <Separator/>
            <MenuItem Header="View">
                <MenuItem Header="Center" Command="{Binding CenterViewCommand}"/>
                <MenuItem Header="Zoom">
                    <MenuItem Header="10%" CommandParameter="0.1" Command="{Binding SetZoomCommand}"/>
                    <MenuItem Header="20%" CommandParameter="0.2" Command="{Binding SetZoomCommand}"/>
                    <MenuItem Header="40%" CommandParameter="0.4" Command="{Binding SetZoomCommand}"/>
                    <MenuItem Header="60%" CommandParameter="0.6" Command="{Binding SetZoomCommand}"/>
                    <MenuItem Header="80%" CommandParameter="0.8" Command="{Binding SetZoomCommand}"/>
                    <MenuItem Header="100%" CommandParameter="1.0" Command="{Binding SetZoomCommand}"/>
                    <MenuItem Header="120%" CommandParameter="1.2" Command="{Binding SetZoomCommand}"/>
                    <MenuItem Header="150%" CommandParameter="1.5" Command="{Binding SetZoomCommand}"/>
                    <MenuItem Header="200%" CommandParameter="2.0" Command="{Binding SetZoomCommand}"/>
                    <MenuItem Header="250%" CommandParameter="2.5" Command="{Binding SetZoomCommand}"/>
                    <MenuItem Header="300%" CommandParameter="3.0" Command="{Binding SetZoomCommand}"/>
                </MenuItem>
            </MenuItem>
        </ContextMenu>
    </Application.Resources>
</Application>