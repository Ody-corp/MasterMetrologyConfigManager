<Application x:Class="MasterMetrology.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MasterMetrology"
             xmlns:v="clr-namespace:MasterMetrology.Models.Visual"
             xmlns:controls="clr-namespace:MasterMetrology.Controls"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <DataTemplate x:Key="StateVertexTemplate" DataType="{x:Type v:GraphVertex}">
            <Border Background="#225577" CornerRadius="8" Padding="5" BorderBrush="LightSteelBlue" BorderThickness="1">
                <TextBlock Text="{Binding State.Name}" Foreground="Red" FontWeight="SemiBold" Background="Pink"/>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SectionVertexTemplate" DataType="{x:Type v:GraphVertexSection}">
            <!--<controls:StateSection SectionData="{Binding Section}"/>-->
            <Border>
                <TextBlock Text="{Binding Section.Name}"/>
            </Border>
        </DataTemplate>
    </Application.Resources>

</Application>
